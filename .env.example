# Shinobi no Sho - configuration locale
# Copier ce fichier en .env et adapter selon votre installation.

# LLM backend (llama.cpp ou ollama, OpenAI compatible)
LLM_BACKEND_URL=http://127.0.0.1:8080
LLM_MODEL_NAME=qwen3-8b-instruct
LLM_MODEL_PATH=models/llm/Qwen3-8B-UD-Q5_K_XL.gguf
LLM_TEMPERATURE=0.7
LLM_TEMPERATURE_STRUCTURED=0.3
LLM_MAX_TOKENS=2048
LLM_CONTEXT_SIZE=16384
LLM_TIMEOUT_SECONDS=180
LLM_GPU_LAYERS=99
LLM_DISABLE_THINKING=true

# Embeddings
EMBEDDINGS_MODEL_NAME=BAAI/bge-m3
EMBEDDINGS_DEVICE=cuda

# Stockage
CHROMA_PERSIST_PATH=./data/embeddings
SAVES_PATH=./data/saves
CANONICAL_DATA_PATH=./data/canonical
RAW_DATA_PATH=./data/raw
MODELS_PATH=./data/models

# Sauvegardes
SAVES_COMPRESS_PAYLOADS=true
SAVES_PRUNE_OLD_SNAPSHOTS=false
SAVES_SNAPSHOT_INTERVAL=50

# Logs
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/shinobi.log
LOG_CONSOLE_PRETTY=true

# Profil de canonicite par defaut
# Sources possibles separees par des virgules :
# manga, boruto_manga, tbv, databook, movie_canon, movie_filler, anime_filler, novel, game
CANONICITY_PROFILE_SOURCES=manga,boruto_manga,tbv,databook,movie_canon

# Scraping (Phase 1 uniquement)
SCRAPER_USER_AGENT=ShinobiNoSho/0.1 (private project, contact@example.local)
SCRAPER_DELAY_SECONDS=1.5
SCRAPER_CONCURRENCY=3
